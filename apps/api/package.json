{
  "name": "@fbm/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts | pino-pretty --colorize",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate -d $DATABASE_URL up",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@fbm/shared": "workspace:*",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/session": "^10.8.0",
    "@fastify/websocket": "^8.3.1",
    "nodemailer": "^6.9.14",
    "pg-boss": "^9.0.3",
    "pino": "^9.3.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20.14.10",
    "node-pg-migrate": "^7.6.1",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
